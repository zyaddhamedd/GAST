generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      String   @default("ADMIN")
  createdAt DateTime @default(now())
}

model Category {
  id        Int       @id @default(autoincrement())
  name      String
  slug      String    @unique
  image     String
  createdAt DateTime  @default(now())
  products  Product[]

  @@index([slug])
}

model ProductImage {
  id        Int     @id @default(autoincrement())
  url       String
  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Product {
  id          Int            @id @default(autoincrement())
  name        String
  subtitle    String?
  description String
  price       Float
  oldPrice    Float?
  discount    Float?
  inStock     Boolean        @default(true)
  power       Float?
  voltage     String?
  specs       Json?
  categoryId  Int
  createdAt   DateTime       @default(now())
  slug        String         @unique
  orderItems  OrderItem[]
  category    Category       @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  images      ProductImage[]

  @@index([categoryId])
  @@index([price])
  @@index([power])
  @@index([voltage])
  @@index([createdAt(sort: Desc)])
}

model Order {
  id                Int           @id @default(autoincrement())
  customerName      String
  phone             String
  email             String?
  address           String
  total             Float
  status            OrderStatus   @default(PENDING)
  createdAt         DateTime      @default(now())
  paymentMethod     PaymentMethod @default(COD)
  paymentProofImage String?
  updatedAt         DateTime      @updatedAt
  items             OrderItem[]

  @@index([status])
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  productId Int
  quantity  Int
  price     Float
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([productId])
}

model Message {
  id         Int      @id @default(autoincrement())
  name       String
  phone      String
  email      String?
  message    String
  readStatus Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([readStatus])
}

enum PaymentMethod {
  COD
  INSTAPAY
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  PENDING_VERIFICATION
  REJECTED
}
