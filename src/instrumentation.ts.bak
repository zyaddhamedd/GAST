export async function register() {
  // Only run in Node.js runtime and NOT during the build phase
  if (process.env.NEXT_RUNTIME === 'nodejs' && process.env.NEXT_IS_EXPORT_WORKER !== 'true') {
    const { prisma } = await import('@/lib/prisma');
    
    try {
      console.log('[Instrumentation] Warming up Prisma...');
      // Use a simple query to initialize the connection pool
      await prisma.$queryRaw`SELECT 1`;
      console.log('[Instrumentation] Prisma is ready.');
    } catch (e) {
      console.warn('[Instrumentation] Prisma warmup skipped or failed:', e);
    }
  }
}
